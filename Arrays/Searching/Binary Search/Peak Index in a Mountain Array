A mountain array increases first and then decreases.

Find the index of the peak element.

Example

Input:  arr = [0,2,5,3,1]
Output: 2

class Solution:
    def peakIndexInMountainArray(self, arr):

        left = 0
        right = len(arr) - 1

        while left < right:

            mid = (left + right) // 2

            if arr[mid] < arr[mid + 1]:
                left = mid + 1
            else:
                right = mid

        return left
